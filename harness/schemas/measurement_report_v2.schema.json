{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dftr.measurement.report.v2",
  "title": "Measurement report v2",
  "type": "object",
  "required": ["artifact_schema", "evidence_class", "counts", "hashes", "seeds", "checkpoint_manifest", "distribution", "quality", "repetition", "authorship", "promotion"],
  "properties": {
    "artifact_schema": {"const": "dftr.measurement.report.v2"},
    "evidence_class": {"enum": ["prospective_screen", "post_hoc_shadow"]},
    "counts": {
      "type": "object",
      "required": ["documents_per_cell", "human_documents_per_panel", "effective_prompt_clusters"],
      "properties": {
        "documents_per_cell": {"type": "integer", "minimum": 64},
        "human_documents_per_panel": {"type": "integer", "minimum": 64},
        "effective_prompt_clusters": {"type": "integer", "minimum": 64}
      }
    },
    "hashes": {
      "type": "object",
      "required": ["protocol_sha256", "prompt_panel_sha256", "human_eval_sha256", "human_floor_a_sha256", "human_floor_b_sha256", "bandwidths_sha256", "power_plan_sha256", "calibration_sha256", "matched_baseline_sha256", "selection_policy_sha256", "candidate_full_brief_sha256", "control_full_brief_sha256", "sampling_grid_sha256", "control_output_manifest_sha256", "dependency_lock_sha256", "evaluator_commit_sha256"],
      "additionalProperties": {"$ref": "#/$defs/sha256"}
    },
    "seeds": {"type": "object", "required": ["training", "sampling", "cells"]},
    "checkpoint_manifest": {"type": "object"},
    "distribution": {
      "type": "object",
      "required": ["bandwidth_sha256", "candidate_mmd2_unbiased", "control_mmd2_unbiased", "human_floor_mmd2_unbiased", "permutation_seed"]
    },
    "quality": {"type": "object", "required": ["status"]},
    "repetition": {"type": "object", "required": ["status"]},
    "authorship": {"type": "object", "required": ["status", "effective_clusters", "fit_count"]},
    "promotion": {"type": "object", "required": ["eligible"], "properties": {"eligible": {"type": "boolean"}}},
    "hard_gates": {"type": "object"},
    "candidate_output_binding": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "sha256": {"$ref": "#/$defs/sha256"}
      }
    },
    "operator_signature": {"$ref": "#/$defs/signature"}
  },
  "allOf": [{
    "if": {"properties": {"promotion": {"properties": {"eligible": {"const": true}}}}},
    "then": {
      "required": ["hard_gates", "candidate_output_binding", "operator_signature"],
      "properties": {
        "hashes": {"required": ["candidate_output_manifest_sha256"]}
      }
    }
  }],
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "signature": {
      "type": "object",
      "required": ["algorithm", "key_id", "signed_payload_sha256", "signature_base64"],
      "properties": {"algorithm": {"const": "ed25519"}}
    }
  }
}
