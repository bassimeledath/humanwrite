{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dftr.measurement.protocol.v2",
  "title": "Frozen prospective measurement protocol v2",
  "type": "object",
  "required": ["artifact_schema", "status", "frozen", "design", "hashes", "panels", "bandwidth_contract", "power", "seeds", "selection_policy", "required_hard_gates", "matched_design", "artifact_bindings", "operator_approval", "operator_signature"],
  "properties": {
    "artifact_schema": {"const": "dftr.measurement.protocol.v2"},
    "status": {"const": "ready"},
    "frozen": {"const": true},
    "design": {
      "type": "object",
      "required": ["documents_per_cell", "human_pool_documents", "replacement_sampling"],
      "properties": {
        "documents_per_cell": {"type": "integer", "minimum": 64},
        "human_pool_documents": {"type": "integer", "minimum": 192},
        "replacement_sampling": {"const": false}
      }
    },
    "hashes": {
      "type": "object",
      "required": ["dependency_lock_sha256", "metric_code_sha256", "prompt_panel_sha256", "prompt_brief_sha256", "human_panels_sha256", "human_panel_contents_sha256", "bandwidths_sha256", "power_plan_sha256", "calibration_sha256", "matched_baseline_sha256", "matched_baseline_outputs_sha256", "selection_policy_sha256"],
      "additionalProperties": {"$ref": "#/$defs/sha256"}
    },
    "panels": {"type": "object"},
    "bandwidth_contract": {"type": "object"},
    "power": {"type": "object"},
    "seeds": {"type": "object"},
    "selection_policy": {"type": "object"},
    "required_hard_gates": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {"type": "string", "minLength": 1}
    },
    "matched_design": {"type": "object"},
    "artifact_bindings": {
      "type": "object",
      "required": ["dependency_lock", "metric_code", "prompt_panel", "prompt_brief", "human_panels", "human_panel_contents", "bandwidths", "power_plan", "calibration", "matched_baseline", "matched_baseline_outputs", "selection_policy"]
    },
    "operator_approval": {
      "type": "object",
      "required": ["approved", "reviewer", "reviewed_at"],
      "properties": {
        "approved": {"const": true},
        "reviewer": {"type": "string", "minLength": 1},
        "reviewed_at": {"type": "string", "minLength": 1}
      }
    },
    "operator_signature": {"$ref": "#/$defs/signature"}
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "signature": {
      "type": "object",
      "required": ["algorithm", "key_id", "signed_payload_sha256", "signature_base64"],
      "properties": {"algorithm": {"const": "ed25519"}}
    }
  }
}
