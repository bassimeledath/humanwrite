#!/usr/bin/env python3
"""Constrained client for the human-operated Modal GPU gateway.

The research agent may invoke this file, but it never receives Modal, Hugging
Face, or OpenRouter credentials.  Its only credential is a capability token
for the gateway, whose server repeats every policy check before launching.
"""
from __future__ import annotations

import argparse
import hashlib
import json
import os
from pathlib import Path
import subprocess
import sys
import time
import uuid
from urllib import error, parse, request


ROOT = Path(__file__).resolve().parents[1]
if str(ROOT) not in sys.path:
    sys.path.insert(0, str(ROOT))

from infra.backend.local_backend import (  # noqa: E402
    budget_local,
    cancel_local,
    logs_local,
    status_local,
    submit_local,
)
from infra.backend.policy import (  # noqa: E402
    REPLAY_GENERATION_CONTRACT_PATH,
    REPLAY_GENERATION_CONTRACT_SHA256,
    REPLAY_HISTORICAL_CONFIG_PATH,
    REPLAY_HISTORICAL_CONFIG_SHA256,
    REPLAY_PROTOCOLS,
    REPLAY_TRANSFORMERS_VERSION,
    PolicyError,
    forbidden_replay_surface_keys,
    validate_replay_launch_contract,
    validate_dft_generation_launch_config,
    validate_estimator_audit_launch_config,
)

LEDGER = ROOT / "ledger" / "ledger.py"
BUDGET = {
    "smoke": {"max_min": 20, "max_gpus": 1},
    "screen": {"max_min": 120, "max_gpus": 1},
    "promo": {"max_min": 480, "max_gpus": 1},
}
UNRESOLVED_REVISION_PREFIX = "__M1_RESOLVE_"
DFT_PROTOCOL = "dftr.m2.score_function_mmd.v1"
DFT_GENERATION_PROTOCOL = "dftr.m2.adapter_native_generation.v1"
ESTIMATOR_AUDIT_PROTOCOL = "dftr.m2.frozen_estimator_audit.v1"
PREPARE_DFT_PROTOCOL = "dftr.m2.prepare_training_bandwidths.v1"
PREPARE_DFT_SUPPORTED_GPUS = {"L40S", "A100-80GB", "H100"}
LOWER_VARIANCE_BRIEF_PROTOCOL = "dftr.lower_variance_briefs.two_provider.v1"
PREPARE_DFT_METHOD_KEYS = (
    "artifact_schema", "run", "compute", "model", "initial_adapter", "data",
    "representation", "derivation", "runtime", "output",
)
PREPARE_DFT_DERIVATION = {
    "algorithm": "median_positive_unordered_human_pairwise_squared_distance.v1",
    "scales": [0.25, 0.5, 1.0, 2.0, 4.0],
    "pair_scope": "all_unordered_training_human_pairs",
    "zero_distance_policy": "fail",
    "degenerate_policy": "fail",
    "distance_dtype": "float64_cpu",
}


def _die(message: str, code: int = 2) -> "None":
    print(message, file=sys.stderr)
    raise SystemExit(code)


def _use_local_backend() -> bool:
    return os.environ.get("DFTR_GPU_BACKEND", "").casefold() == "local"


def _is_checkpoint_volume_path(path: Path) -> bool:
    """Return whether an absolute path resolves strictly below /checkpoints."""
    if not path.is_absolute():
        return False
    try:
        checkpoint_root = Path("/checkpoints").resolve(strict=False)
        resolved = path.resolve(strict=False)
        return resolved != checkpoint_root and resolved.is_relative_to(checkpoint_root)
    except (OSError, RuntimeError, ValueError):
        return False


def _gateway_config() -> tuple[str, str]:
    if _use_local_backend():
        return "local://offline", "local"
    url = os.environ.get("DFTR_GPU_GATEWAY_URL", "").rstrip("/")
    token = os.environ.get("DFTR_GPU_GATEWAY_TOKEN", "")
    if not url or not token:
        _die(
            "DFTR_GPU_GATEWAY_URL and DFTR_GPU_GATEWAY_TOKEN must be set. "
            "Provider credentials must not be placed in this shell."
        )
    if parse.urlparse(url).scheme != "https":
        _die("DFTR_GPU_GATEWAY_URL must use https")
    return url, token


def _api(method: str, path: str, payload: dict | None = None) -> dict:
    if _use_local_backend():
        try:
            if method == "POST" and path == "/submit":
                return submit_local(payload or {})
            if method == "GET" and path.startswith("/status/"):
                return status_local(parse.unquote(path.rsplit("/", 1)[-1]))
            if method == "GET" and path.startswith("/logs/"):
                run_id, _, query = path.partition("?")
                tail = int(parse.parse_qs(query).get("tail", ["200"])[0])
                return logs_local(parse.unquote(run_id.rsplit("/", 1)[-1]), tail=tail)
            if method == "POST" and path.startswith("/cancel/"):
                return cancel_local(parse.unquote(path.rsplit("/", 1)[-1]))
            if method == "GET" and path == "/budget":
                return budget_local()
        except Exception as exc:
            _die(f"local backend rejected request: {exc}")
        _die(f"unsupported local backend route: {method} {path}")
    base, token = _gateway_config()
    body = None if payload is None else json.dumps(payload).encode("utf-8")
    req = request.Request(
        f"{base}{path}",
        data=body,
        method=method,
        headers={
            "Authorization": f"Bearer {token}",
            "Content-Type": "application/json",
            "User-Agent": "dftr-gpu-client/1",
        },
    )
    try:
        with request.urlopen(req, timeout=60) as response:
            return json.load(response)
    except error.HTTPError as exc:
        try:
            detail = json.loads(exc.read().decode("utf-8")).get("detail")
        except Exception:
            detail = None
        _die(f"gateway rejected request ({exc.code}): {detail or exc.reason}")
    except error.URLError as exc:
        _die(f"gateway unavailable: {exc.reason}")


def _load_config(path: str) -> dict:
    try:
        import yaml
    except ImportError:
        _die("PyYAML is required: python -m pip install pyyaml")
    config_path = Path(path).resolve()
    if not config_path.is_file():
        _die(f"config not found: {config_path}")
    try:
        value = yaml.safe_load(config_path.read_text(encoding="utf-8"))
    except Exception as exc:
        _die(f"invalid YAML config: {exc}")
    if not isinstance(value, dict):
        _die("config must be a YAML mapping")
    return value


def _config_hash(config: dict) -> str:
    canonical = json.dumps(config, sort_keys=True, separators=(",", ":"))
    return hashlib.sha256(canonical.encode("utf-8")).hexdigest()


def _git_sha() -> str:
    try:
        return subprocess.check_output(
            ["git", "-C", str(ROOT), "rev-parse", "HEAD"], text=True
        ).strip()
    except subprocess.CalledProcessError:
        _die("repository has no git commit; commit the experiment code first")


def _preregistration(comparison_id: str) -> dict:
    try:
        output = subprocess.check_output(
            [sys.executable, str(LEDGER), "query", "--comparison", comparison_id, "--open"],
            text=True,
        )
        rows = json.loads(output or "[]")
    except Exception:
        rows = []
    if not rows:
        _die(
            f"REJECTED: no open preregistration for comparison_id={comparison_id}. "
            f"Run: ledger/ledger.py add --comparison {comparison_id} --hypothesis ... first."
        )
    return rows[-1]


def _validate_submit(config: dict, budget_class: str) -> tuple[str, dict]:
    if budget_class not in BUDGET:
        _die(f"unknown budget class {budget_class}")
    run = config.get("run")
    if not isinstance(run, dict) or not run.get("comparison_id"):
        _die("config.run.comparison_id is required")
    if run.get("budget_class") not in (None, budget_class):
        _die("budget_class mismatch between flag and config")
    compute = config.get("compute") or {}
    if int(compute.get("gpus", 1)) != 1:
        _die("REJECTED: single-GPU rule; compute.gpus must equal 1")
    requested_min = int(compute.get("timeout_min", BUDGET[budget_class]["max_min"]))
    if requested_min <= 0 or requested_min > BUDGET[budget_class]["max_min"]:
        _die(
            f"REJECTED: timeout_min={requested_min} exceeds {budget_class} limit "
            f"of {BUDGET[budget_class]['max_min']}"
        )
    base_model = str((config.get("model") or {}).get("base", ""))
    workflow_step = str((config.get("workflow") or {}).get("step", "")).casefold()
    if "14B" in base_model.upper() and os.environ.get("DFTR_ALLOW_SCALEUP") != "1":
        _die("REJECTED: 14B/scale-up requires human DFTR_ALLOW_SCALEUP=1")
    revision = str((config.get("model") or {}).get("revision", "")).strip()
    if workflow_step in {
        "train_sft", "sample_sweep", "merge_adapter", "replay_equivalence", "train_dft",
        "prepare_dft", "generate_dft", "audit_estimator",
    } and (
        not revision or revision.startswith(UNRESOLVED_REVISION_PREFIX)
    ):
        _die("REJECTED: evidentiary experiment jobs require a resolved immutable model.revision")
    if workflow_step == "train_dft":
        workflow = config.get("workflow") or {}
        execution_arm = str((config.get("execution") or {}).get("arm") or "")
        if workflow.get("protocol_version") != DFT_PROTOCOL or execution_arm not in {"A0", "A64"}:
            _die("REJECTED: train_dft requires the frozen protocol and A0/A64 selector")
        if execution_arm == "A64":
            if _use_local_backend():
                _die("REJECTED: A64 requires the independently configured Modal gateway")
            readiness_path = os.environ.get("DFTR_M2_A64_READINESS_MANIFEST", "")
            readiness_sha = os.environ.get("DFTR_M2_A64_READINESS_SHA256", "")
            path = Path(readiness_path)
            if (
                not path.is_absolute()
                or len(readiness_sha) != 64
                or any(character not in "0123456789abcdef" for character in readiness_sha)
            ):
                _die("REJECTED: A64 requires wrapper-bound readiness path and SHA-256")
            if not readiness_path.startswith("/checkpoints/"):
                _die("REJECTED: Modal A64 readiness must use the checkpoint volume")
    if workflow_step == "prepare_dft":
        workflow = config.get("workflow") or {}
        method_payload = {key: config.get(key) for key in PREPARE_DFT_METHOD_KEYS}
        method_payload.update(
            protocol_version=workflow.get("protocol_version"), step=workflow.get("step")
        )
        adapter_path = Path(str((config.get("initial_adapter") or {}).get("path") or ""))
        human_path = Path(str((config.get("data") or {}).get("human_targets_path") or ""))
        if (
            set(config) != set(PREPARE_DFT_METHOD_KEYS) | {"workflow"}
            or config.get("artifact_schema") != PREPARE_DFT_PROTOCOL
            or workflow.get("protocol_version") != PREPARE_DFT_PROTOCOL
            or _config_hash(method_payload) != workflow.get("preparation_contract_sha256")
            or str(run.get("task_kind")) != "experiment"
            or budget_class != "smoke"
            or run.get("arm") != "training-bandwidths"
            or str(compute.get("gpu") or "").upper() not in PREPARE_DFT_SUPPORTED_GPUS
            or compute.get("gpus") != 1
            or isinstance(compute.get("gpus"), bool)
            or config.get("model") != {
                "base": "Qwen/Qwen3-4B",
                "revision": "1cfa9a7208912126459214e8b04321603b3df60c",
                "torch_dtype": "bfloat16",
            }
            or config.get("derivation") != PREPARE_DFT_DERIVATION
            or config.get("output") != {"filename": "training_bandwidths.json", "overwrite": False}
            or not adapter_path.is_absolute()
            or not human_path.is_absolute()
            or any(part in {"harness", "measurement_v2"} for part in human_path.parts)
        ):
            _die("REJECTED: prepare_dft requires the exact frozen wrapper-only protocol")
        if not _use_local_backend() and (
            not _is_checkpoint_volume_path(adapter_path)
            or not _is_checkpoint_volume_path(human_path)
        ):
            _die("REJECTED: Modal prepare_dft inputs must use the checkpoint volume")
    if workflow_step == "generate_dft":
        try:
            validate_dft_generation_launch_config(
                config,
                backend="local" if _use_local_backend() else "modal",
                budget_class=budget_class,
                task_kind=str(run.get("task_kind") or ""),
            )
        except PolicyError as exc:
            _die(f"REJECTED: {exc}")
    if workflow_step == "audit_estimator":
        try:
            validate_estimator_audit_launch_config(
                config,
                backend="local" if _use_local_backend() else "modal",
                budget_class=budget_class,
                task_kind=str(run.get("task_kind") or ""),
            )
        except PolicyError as exc:
            _die(f"REJECTED: {exc}")
    if workflow_step == "train_lower_variance":
        try:
            from experiments.m2.lower_variance_train import validate_lower_variance_config

            validate_lower_variance_config(config)
        except Exception as exc:
            _die(f"REJECTED: lower-variance config invalid: {exc}")
    if workflow_step == "replay_equivalence":
        replay_workflow = config.get("workflow") or {}
        protocol_version = str(replay_workflow.get("protocol_version"))
        if protocol_version not in REPLAY_PROTOCOLS:
            _die("REJECTED: replay_equivalence requires the frozen public replay protocol")
        if str(run.get("task_kind", "experiment")) != "experiment":
            _die("REJECTED: replay_equivalence requires the credential-free experiment task kind")
        forbidden = forbidden_replay_surface_keys(config)
        if forbidden:
            _die("REJECTED: replay_equivalence cannot expose paid or hidden surfaces")
        if str((config.get("runtime") or {}).get("transformers_version")) != REPLAY_TRANSFORMERS_VERSION:
            _die("REJECTED: replay_equivalence requires the exact frozen Transformers version")
        expected_bindings = {
            "generation_contract": REPLAY_GENERATION_CONTRACT_PATH,
            "generation_contract_sha256": REPLAY_GENERATION_CONTRACT_SHA256,
            "historical_sampling_config": REPLAY_HISTORICAL_CONFIG_PATH,
            "historical_sampling_config_sha256": REPLAY_HISTORICAL_CONFIG_SHA256,
        }
        if any(str(replay_workflow.get(key) or "") != value for key, value in expected_bindings.items()):
            _die("REJECTED: replay_equivalence requires canonical frozen contract bindings")
        try:
            validate_replay_launch_contract(config)
        except PolicyError as exc:
            _die(f"REJECTED: {exc}")
    task_kind = str(run.get("task_kind", "experiment"))
    if task_kind == "experiment":
        command = run.get("command", ["python", "-m", "experiments.runner"])
        if not isinstance(command, list) or command[:3] != ["python", "-m", "experiments.runner"]:
            _die("run.command must begin with: python -m experiments.runner")
    elif task_kind in {"brief_synthesis", "document_cleaning"}:
        api_cap = float((config.get("api") or {}).get("max_cost_usd", 0.0))
        if api_cap <= 0 or api_cap > 100:
            _die(f"{task_kind} requires 0 < api.max_cost_usd <= 100")
        data = config.get("data") or {}
        input_sha = str(data.get("input_sha256", ""))
        if len(input_sha) != 64 or any(character not in "0123456789abcdef" for character in input_sha):
            _die(f"{task_kind} requires lowercase data.input_sha256")
        api = config.get("api") or {}
        if task_kind == "document_cleaning":
            if not str(api.get("model", "")):
                _die("document_cleaning requires a frozen api.model")
            if api.get("model") != "qwen/qwen3-32b":
                _die("document_cleaning requires qwen/qwen3-32b")
            if data.get("input_uri") == data.get("output_uri"):
                _die("document_cleaning input and output must be distinct")
        elif api.get("protocol") == LOWER_VARIANCE_BRIEF_PROTOCOL:
            if (
                api.get("metadata_model") != "qwen/qwen3-32b"
                or api.get("outline_model") != "openai/gpt-5-mini"
            ):
                _die("lower-variance brief provider models are frozen")
            if data.get("input_uri") == data.get("output_uri"):
                _die("lower-variance brief input and output URIs must be distinct")
            if int(data.get("max_records", 0)) not in {128, 1024}:
                _die("lower-variance brief corpus must contain 128 or 1024 records")
        elif api.get("prompt_repair_only") is True:
            if not str(api.get("model", "")):
                _die("brief_synthesis requires a frozen api.model")
            if api.get("force_empty_quotations") is True:
                _die("prompt repair cannot also run quote-free recovery")
            if data.get("input_uri") == data.get("output_uri"):
                _die("prompt repair input and output URIs must be distinct")
            if int(data.get("max_records", 0)) > 320:
                _die("prompt repair is limited to the frozen 320-record corpus")
        elif not str(api.get("model", "")):
            _die("brief_synthesis requires a frozen api.model")
    elif task_kind == "source_materialization":
        data = config.get("data") or {}
        for field in ("train_output_uri", "dev_output_uri", "manifest_output_uri"):
            if not str(data.get(field, "")).startswith(
                "modal-volume://humanwrite-checkpoints/"
            ):
                _die(f"source_materialization data.{field} must use the checkpoint volume")
    else:
        _die("run.task_kind is not allowlisted")
    return str(run["comparison_id"]), _preregistration(str(run["comparison_id"]))


def _ledger_add(run_id: str, comparison: str, config_hash: str, git_sha: str,
                budget_class: str, config: dict) -> None:
    data_hash = str((config.get("data") or {}).get("train_split_hash", ""))
    subprocess.run(
        [
            sys.executable, str(LEDGER), "add",
            "--run-id", run_id,
            "--comparison", comparison,
            "--config-hash", config_hash,
            "--git-sha", git_sha,
            "--budget-class", budget_class,
            "--data-split-hash", data_hash,
        ],
        check=True,
    )


def _ledger_failure(run_id: str) -> None:
    subprocess.run(
        [sys.executable, str(LEDGER), "update", "--run-id", run_id,
         "--status", "launch_failed"],
        check=False,
    )


def submit(args: argparse.Namespace) -> None:
    config = _load_config(args.config)
    comparison, prereg = _validate_submit(config, args.budget_class)
    if not _use_local_backend():
        _gateway_config()  # fail before touching the append-only ledger
    config_hash = _config_hash(config)
    git_sha = _git_sha()
    run_id = f"dftr-{int(time.time())}-{uuid.uuid4().hex[:8]}"
    _ledger_add(run_id, comparison, config_hash, git_sha, args.budget_class, config)
    try:
        payload = {
            "run_id": run_id,
            "config": config,
            "config_hash": config_hash,
            "git_sha": git_sha,
            "budget_class": args.budget_class,
            "preregistration": prereg,
            "human_scaleup_approved": os.environ.get("DFTR_ALLOW_SCALEUP") == "1",
        }
        if (
            str((config.get("workflow") or {}).get("step", "")).casefold() == "train_dft"
            and str((config.get("execution") or {}).get("arm")) == "A64"
        ):
            payload["dft_a64_readiness"] = {
                "kind": "dft_a64_readiness",
                "status": "ready",
                "comparison": comparison,
                "method_contract_sha256": str(
                    (config.get("workflow") or {}).get("method_contract_sha256") or ""
                ),
                "manifest_path": os.environ["DFTR_M2_A64_READINESS_MANIFEST"],
                "manifest_sha256": os.environ["DFTR_M2_A64_READINESS_SHA256"],
            }
        result = _api("POST", "/submit", payload)
    except SystemExit:
        _ledger_failure(run_id)
        raise
    print(json.dumps(result, indent=2, sort_keys=True))


def status(args: argparse.Namespace) -> None:
    print(json.dumps(_api("GET", f"/status/{parse.quote(args.run_id)}"), indent=2))


def logs(args: argparse.Namespace) -> None:
    query = parse.urlencode({"tail": args.tail})
    result = _api("GET", f"/logs/{parse.quote(args.run_id)}?{query}")
    print(result.get("logs", ""))


def cancel(args: argparse.Namespace) -> None:
    result = _api("POST", f"/cancel/{parse.quote(args.run_id)}", {})
    print(json.dumps(result, indent=2))


def budget(args: argparse.Namespace) -> None:
    print(json.dumps(_api("GET", "/budget"), indent=2, sort_keys=True))


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(prog="gpu")
    sub = parser.add_subparsers(dest="cmd", required=True)
    ps = sub.add_parser("submit")
    ps.add_argument("--config", required=True)
    ps.add_argument("--budget-class", required=True)
    ps.set_defaults(func=submit)
    pstatus = sub.add_parser("status")
    pstatus.add_argument("run_id")
    pstatus.set_defaults(func=status)
    plogs = sub.add_parser("logs")
    plogs.add_argument("run_id")
    plogs.add_argument("--tail", type=int, default=200)
    plogs.set_defaults(func=logs)
    pcancel = sub.add_parser("cancel")
    pcancel.add_argument("run_id")
    pcancel.set_defaults(func=cancel)
    pbudget = sub.add_parser("budget")
    pbudget.set_defaults(func=budget)
    args = parser.parse_args(argv)
    args.func(args)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
